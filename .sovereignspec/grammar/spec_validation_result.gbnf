# GBNF grammar for spec validation result output
# Produces structured JSON with validation errors per spec

root     ::= object
object   ::= "{" ws pair ("," ws pair)* ws "}"
pair     ::= string ":" value
string   ::= "\"" char* "\""
char     ::= [^"\\] | "\\" (["\\/bfnrt] | "u" [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F])
value    ::= object | array | string | number | "true" | "false" | "null"
number   ::= "-"? ("0" | [1-9] [0-9]*) ("." [0-9]+)? ([eE] [+-]? [0-9]+)?
array    ::= "[" ws (value ("," ws value)*)? ws "]"
ws       ::= [ \t\n\r]*

# Top-level spec: a list of validation results
top      ::= "{" ws "\"results\"" ws ":" ws results_array ws "}"
results_array ::= "[" ws result_entry ("," ws result_entry)* ws "]"
result_entry ::= "{" ws "\"spec_id\"" ws ":" ws string ws "," ws "\"valid\"" ws ":" ws ("true" | "false") ws "," ws "\"errors\"" ws ":" ws error_array ws "}"
error_array  ::= "[" ws error_entry ("," ws error_entry)* ws "]"
error_entry  ::= "{" ws "\"code\"" ws ":" ws string ws "," ws "\"message\"" ws ":" ws string ws "}"
